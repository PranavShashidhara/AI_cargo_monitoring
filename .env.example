# Copy this file to `.env` and fill in values. Do not commit `.env`.

# -----------------------------------------------------------------------------
# Required — Anthropic API (Claude) for LLM-powered agents in the workflow
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Optional — SMTP email alerts (e.g. operator notifications)
# Gmail: use an App Password, not your normal account password.
# -----------------------------------------------------------------------------
EMAIL_FROM=
EMAIL_PASSWORD=
ALERT_EMAIL=

# Optional overrides (defaults match Gmail-style SMTP if unset)
# EMAIL_SMTP_SERVER=smtp.gmail.com
# EMAIL_SMTP_PORT=587
